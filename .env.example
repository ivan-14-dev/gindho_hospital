# ============================================================================
# GinDHO — Environment Variables Template
# ============================================================================
# Copy this file to .env and fill in all values marked with <CHANGE_ME>
# NEVER commit .env to version control
# Run: cp .env.example .env && nano .env
# ============================================================================

# --- Database ---
DB_URL=jdbc:postgresql://postgres:5432/gindho
DB_USERNAME=gindho
DB_PASSWORD=<CHANGE_ME_STRONG_PASSWORD>
DB_HOST=postgres
DB_PORT=5432

# --- PostgreSQL (Docker) ---
POSTGRES_USER=gindho
POSTGRES_PASSWORD=<CHANGE_ME_STRONG_PASSWORD>
POSTGRES_DB=gindho
POSTGRES_PORT=5432

# --- MongoDB (Docker) ---
MONGO_USERNAME=gindho
MONGO_PASSWORD=<CHANGE_ME_STRONG_PASSWORD>
MONGO_PORT=27017

# --- Redis (Docker) ---
REDIS_PORT=6379

# --- Kafka ---
KAFKA_PORT=9092

# --- Keycloak ---
KC_DB_USERNAME=keycloak
KC_DB_PASSWORD=<CHANGE_ME_STRONG_PASSWORD>
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=<CHANGE_ME_STRONG_PASSWORD>
KEYCLOAK_PORT=8080

# --- JWT (legacy — migration to Keycloak OIDC in progress) ---
JWT_SECRET=<CHANGE_ME_256_BIT_SECRET>
JWT_EXPIRATION_MS=86400000

# --- Mail ---
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=<CHANGE_ME_EMAIL>
MAIL_PASSWORD=<CHANGE_ME_APP_PASSWORD>

# --- File Storage ---
FILE_UPLOAD_DIR=uploads
FILE_MAX_SIZE=10MB

# --- Logging ---
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=INFO
LOG_LEVEL_SECURITY=WARN
LOG_LEVEL_WEB=WARN
LOG_FILE=logs/gindho.log

# --- Security (legacy — will be removed after Keycloak migration) ---
SECURITY_DEFAULT_USERNAME=admin
SECURITY_DEFAULT_PASSWORD=<CHANGE_ME_STRONG_PASSWORD>

# --- Async ---
ASYNC_POOL_SIZE=10
ASYNC_POOL_MAX_SIZE=20

# --- Kong ---
KONG_PROXY_PORT=8000
KONG_ADMIN_PORT=8001

# --- Observability ---
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=<CHANGE_ME_STRONG_PASSWORD>
JAEGER_UI_PORT=16686
JAEGER_OTLP_GRPC_PORT=4317
JAEGER_OTLP_HTTP_PORT=4318
LOKI_PORT=3100
