# Configuration pour microservices Kubernetes GinDHO

# Kong API Gateway (point d'entrée unique pour tous les microservices)
VITE_GATEWAY_URL=http://localhost:9000

# Keycloak (authentification OIDC)
VITE_KEYCLOAK_URL=http://localhost:9001
VITE_KEYCLOAK_REALM=gindho
VITE_KEYCLOAK_CLIENT_ID=gindho-frontend

# Environnement
VITE_APP_ENV=development
VITE_APP_VERSION=1.0.0

# Features flags
VITE_ENABLE_AI_ASSISTANT=true
VITE_ENABLE_WEBSOCKET=true
VITE_ENABLE_OFFLINE_MODE=false

# Monitoring
VITE_SENTRY_DSN=your-sentry-dsn-here