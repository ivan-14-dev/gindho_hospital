{
  "title": "GinDHO \u2014 Overview",
  "version": 1,
  "panels": [
    {
      "title": "Service Health",
      "type": "stat",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 0},
      "targets": [{"expr": "up{job=~"microservices"}", "legendFormat": "{{instance}}"}]
    },
    {
      "title": "Request Latency p95",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [{"expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket[5m])) by (le, uri))"}]
    },
    {
      "title": "Error Rate (% 5xx)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [{"expr": "sum(rate(http_server_requests_seconds_count{status=~"5.."}[5m])) / sum(rate(http_server_requests_seconds_count[5m])) * 100"}]
    },
    {
      "title": "JVM Heap Usage",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "targets": [{"expr": "jvm_memory_used_bytes{area="heap"} / 1048576"}]
    },
    {
      "title": "Kafka Consumer Lag",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "targets": [{"expr": "kafka_consumer_lag"}]
    }
  ],
  "tags": ["gindho", "production"],
  "schemaVersion": 39
}