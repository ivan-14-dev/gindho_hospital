{
  "realm": "gindho",
  "displayName": "GinDHO Hospital System",
  "enabled": true,
  "sslRequired": "external",
  "accessTokenLifespan": 3600,
  "refreshTokenLifespan": 86400,
  "clients": [
    {
      "clientId": "gindho-backend",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "gindho-backend-secret",
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": true,
      "redirectUris": ["http://localhost:*"],
      "webOrigins": ["http://localhost:*"]
    },
    {
      "clientId": "gindho-frontend",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "redirectUris": ["http://localhost:*"],
      "webOrigins": ["http://localhost:*"]
    }
  ],
  "roles": {
    "realm": [
      { "name": "SUPER_ADMIN" },
      { "name": "ADMIN" },
      { "name": "MEDECIN" },
      { "name": "NURSE" },
