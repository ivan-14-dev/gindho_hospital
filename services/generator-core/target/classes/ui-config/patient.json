{
  "appName": "patient",
  "version": "1.0",
  "theme": "light",
  "menus": [],
  "sections": [
    {
      "id": "patient",
      "label": "Gestion des patients",
      "icon": "users",
      "order": 1,
      "roles": [
        "ADMIN",
        "MEDECIN",
        "RECEPTION"
      ],
      "permissions": [
        "PATIENT:READ"
      ],
      "children": [],
      "widgets": [
        {
          "id": "patient-list",
          "type": "datatable",
          "title": "Liste des patients",
          "api": "/api/patients",
          "apiMethod": "GET",
          "columns": [
            {
              "field": "numeroPatient",
              "label": "N° Patient",
              "type": "text",
              "width": 120,
              "sortable": true,
              "filterable": true
            },
            {
              "field": "nom",
              "label": "Nom",
              "type": "text",
              "width": 150,
              "sortable": true,
              "filterable": true
            },
            {
              "field": "prenom",
              "label": "Prénom",
              "type": "text",
              "width": 150,
              "sortable": true,
              "filterable": true
            },
            {
              "field": "dateNaissance",
              "label": "Date naiss.",
              "type": "date",
              "width": 100
            },
            {
              "field": "sexe",
              "label": "Sexe",
              "type": "badge",
              "width": 80,
              "badges": [
                {
                  "field": "sexe",
                  "value": "MASCULIN",
                  "color": "blue",
                  "label": "M"
                },
                {
                  "field": "sexe",
                  "value": "FEMININ",
                  "color": "pink",
                  "label": "F"
                }
              ]
            },
            {
              "field": "telephone",
              "label": "Téléphone",
              "type": "text",
              "width": 120
            },
            {
              "field": "email",
              "label": "Email",
              "type": "text",
              "width": 180
            }
          ],
          "fields": [],
          "actions": [
            {
              "label": "Nouveau patient",
              "icon": "plus",
              "action": "create",
              "style": "primary",
              "api": "/api/patients",
              "apiMethod": "POST",
              "permission": "PATIENT:WRITE",
              "openIn": "modal"
            },
            {
              "label": "Modifier",
              "icon": "edit",
              "action": "update",
              "style": "outline",
              "api": "/api/patients/{id}",
              "apiMethod": "PUT",
              "permission": "PATIENT:WRITE",
              "openIn": "modal"
            },
            {
              "label": "Supprimer",
              "icon": "trash",
              "action": "delete",
              "style": "danger",
              "api": "/api/patients/{id}",
              "apiMethod": "DELETE",
              "permission": "PATIENT:DELETE",
              "confirmMessage": "Confirmez la suppression du patient ?"
            }
          ],
          "children": [],
          "refreshInterval": 0
        },
        {
          "id": "patient-form",
          "type": "form",
          "title": "Fiche patient",
          "api": "/api/patients",
          "apiMethod": "POST",
          "columns": [],
          "fields": [
            {
              "name": "nom",
              "label": "Nom",
              "type": "text",
              "required": true,
              "placeholder": "Nom du patient"
            },
            {
              "name": "prenom",
              "label": "Prénom",
              "type": "text",
              "required": true
            },
            {
              "name": "dateNaissance",
              "label": "Date de naissance",
              "type": "date",
              "required": true
            },
            {
              "name": "sexe",
              "label": "Sexe",
              "type": "select",
              "required": true,
              "options": [
                "MASCULIN",
                "FEMININ"
              ]
            },
            {
              "name": "telephone",
              "label": "Téléphone",
              "type": "text",
              "required": true
            },
            {
              "name": "email",
              "label": "Email",
              "type": "email"
            },
            {
              "name": "adresse",
              "label": "Adresse",
              "type": "textarea"
            },
            {
              "name": "groupeSanguin",
              "label": "Groupe sanguin",
              "type": "select",
              "options": [
                "A+",
                "A-",
                "B+",
                "B-",
                "AB+",
                "AB-",
                "O+",
                "O-"
              ]
            },
            {
              "name": "personneContact",
              "label": "Personne à contacter",
              "type": "text"
            },
            {
              "name": "telephoneContact",
              "label": "Tél. contact",
              "type": "text"
            }
          ],
          "actions": [
            {
              "label": "Enregistrer",
              "icon": "save",
              "action": "save",
              "style": "primary",
              "api": "/api/patients",
              "apiMethod": "POST",
              "permission": "PATIENT:WRITE",
              "successMessage": "Patient créé avec succès",
              "errorMessage": "Erreur lors de la création"
            }
          ],
          "children": [],
          "refreshInterval": 0
        }
      ]
    },
    {
      "id": "appointment",
      "label": "Rendez-vous",
      "icon": "calendar",
      "order": 2,
      "roles": [
        "ADMIN",
        "MEDECIN",
        "RECEPTION"
      ],
      "permissions": [
        "APPOINTMENT:READ"
      ],
      "children": [],
      "widgets": [
        {
          "id": "appointment-calendar",
          "type": "calendar",
          "title": "Calendrier des rendez-vous",
          "api": "/api/appointments",
          "apiMethod": "GET",
          "columns": [
            {
              "field": "dateHeure",
              "label": "Date/Heure",
              "type": "datetime",
              "width": 150
            },
            {
              "field": "patientNom",
              "label": "Patient",
              "type": "text",
              "width": 200
            },
            {
              "field": "medecinNom",
              "label": "Médecin",
              "type": "text",
              "width": 150
            },
            {
              "field": "statut",
              "label": "Statut",
              "type": "badge",
              "width": 100
            },
            {
              "field": "motif",
              "label": "Motif",
              "type": "text",
              "width": 200
            }
          ],
          "fields": [],
          "actions": [
            {
              "label": "Nouveau RDV",
              "icon": "plus",
              "action": "create",
              "style": "primary",
              "api": "/api/appointments",
              "apiMethod": "POST",
              "permission": "APPOINTMENT:WRITE",
              "openIn": "modal"
            },
            {
              "label": "Confirmer",
              "icon": "check",
              "action": "custom",
              "style": "success",
              "api": "/api/appointments/{id}/confirm",
              "apiMethod": "PUT",
              "permission": "APPOINTMENT:WRITE"
            },
            {
              "label": "Annuler",
              "icon": "times",
              "action": "custom",
              "style": "danger",
              "api": "/api/appointments/{id}/cancel",
              "apiMethod": "PUT",
              "permission": "APPOINTMENT:WRITE",
              "confirmMessage": "Annuler ce rendez-vous ?"
            }
          ],
          "children": [],
          "refreshInterval": 30
        },
        {
          "id": "appointment-form",
          "type": "form",
          "title": "Nouveau rendez-vous",
          "api": "/api/appointments",
          "apiMethod": "POST",
          "columns": [],
          "fields": [
            {
              "name": "patientId",
              "label": "Patient",
              "type": "select",
              "required": true,
              "optionsApi": "/api/patients"
            },
            {
              "name": "medecinId",
              "label": "Médecin",
              "type": "select",
              "required": true,
              "optionsApi": "/api/hr/employees?fonction=MEDECIN"
            },
            {
              "name": "dateHeure",
              "label": "Date et heure",
              "type": "datetime",
              "required": true
            },
            {
              "name": "motif",
              "label": "Motif",
              "type": "textarea",
              "required": true
            },
            {
              "name": "type",
              "label": "Type",
              "type": "select",
              "options": [
                "CONSULTATION",
                "CONTROLE",
                "URGENCE",
                "SUIVI"
              ]
            }
          ],
          "actions": [
            {
              "label": "Prendre RDV",
              "icon": "save",
              "action": "save",
              "style": "primary",
              "api": "/api/appointments",
              "apiMethod": "POST",
              "permission": "APPOINTMENT:WRITE",
              "successMessage": "Rendez-vous créé"
            }
          ],
          "children": [],
          "refreshInterval": 0
        }
      ]
    }
  ]
}