# Variables d'environnement pour Identity Service

# --------------------------------------------------------------------------
# Caractéristiques de la base de données - correspondent à .env dérivé de docker-compose.yml
# --------------------------------------------------------------------------
POSTGRES_USER=${POSTGRES_USER:-gindho}
POSTGRES_PASSWORD=${POSTGRES_PASSWORD:-gindho123}
POSTGRES_DB=identity_service

# --------------------------------------------------------------------------
# JWT Security (correspond au JWT secret principal du .env hospital)
# --------------------------------------------------------------------------
JWT_SECRET=${JWT_SECRET:-mySecretKeyForJWTTokenGeneration1234567890}
JWT_ISSUER=${JWT_ISSUER:-https://gindho-keycloak.apps.gindho.com/realms/gindho}
JWT_AUDIENCE=${JWT_AUDIENCE:-gindho-patient,gindho-billing,gindho-appointments}

# --------------------------------------------------------------------------
# Keycloak pour le login externe (superadmin) - séparé de la base de données locale
# --------------------------------------------------------------------------
KEYCLOAK_ADMIN=${KEYCLOAK_ADMIN:-admin}
KEYCLOAK_ADMIN_PASSWORD=${KEYCLOAK_ADMIN_PASSWORD:-admin123}
KEYCLOAK_URL=${KEYCLOAK_URL:-http://localhost:8080}
KEYCLOAK_REALM=${KEYCLOAK_REALM:-gindho}
KEYCLOAK_CLIENT_ID=${KEYCLOAK_CLIENT_ID:-gindho-frontend}
KEYCLOAK_CLIENT_SECRET=${KEYCLOAK_CLIENT_SECRET:-test-secret}

# --------------------------------------------------------------------------
# Configuration locale du service
# --------------------------------------------------------------------------
SERVER_PORT=${SERVER_PORT:-9001}
spring.datasource.url=jdbc:postgresql://localhost:5433/identity_service
spring.datasource.username=${DB_USERNAME:-gindho}
spring.datasource.password=${DB_PASSWORD:-gindho123}

# --------------------------------------------------------------------------
# Service d'authentification pour la base de données - requis par le login local admin@gindho.com
# --------------------------------------------------------------------------
EXISTING_SUPERADMIN_EMAIL=admin@gindho.com
EXISTING_SUPERADMIN_PASSWORD=admin123
EXISTING_SUPERADMIN_ROLE=SUPER_ADMIN
EXISTING_SUPERADMIN_NOM=Admin
EXISTING_SUPERADMIN_PRENOM=System
EXISTING_SUPERADMIN_HASH_BCRYPT=${EXISTING_SUPERADMIN_HASH_BCRYPT:-\$2a\$12\$LQv3c1yqBWVHxkd0LHAkCOYz6TtxMQJqhN8/X4.qVh.N9NJ.KQXCKa}